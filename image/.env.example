# Dataset/output
DATASET_ROOT=dataset
CSV_UPDATE_INTERVAL=10

# Detector groups. Add/remove full detectors here.
ENABLED_FIRE_DETECTORS=vit_fire,opencv_flame,clip_fire_evidence
ENABLED_SMOKE_DETECTORS=clip_smoke,clip_smoke_plume,opencv_smoke,opencv_dark_smoke,opencv_bright_plume
ENABLED_CONTEXT_DETECTORS=yolo_objects,ocr_text

# Fire thresholds
FIRE_THRESHOLD=0.60
CLIP_VISIBLE_FIRE_THRESHOLD=0.42
MIN_FIRE_PIXEL_PERCENT=0.002
COLOR_FIRE_OVERRIDE_PERCENT=0.006

# Smoke thresholds
CLIP_SMOKE_THRESHOLD=0.42
CLIP_SMOKE_PLUME_THRESHOLD=0.34
OPENCV_SMOKE_THRESHOLD=0.015
OPENCV_DARK_SMOKE_THRESHOLD=0.010
OPENCV_DARK_SMOKE_MIN_REGION_PERCENT=0.002
OPENCV_BRIGHT_PLUME_THRESHOLD=0.020
OPENCV_BRIGHT_PLUME_MIN_REGION_PERCENT=0.004
OPENCV_BRIGHT_PLUME_MIN_TEXTURE=3
OPENCV_BRIGHT_PLUME_REGION_MIN_TEXTURE=4.0

# Smoke decision behavior
SMOKE_REQUIRE_AGREEMENT=false
SMOKE_LOCALIZERS_SUPPORT_ONLY=true
SMOKE_CLASSIFIER_WEAK_SUPPORT_SCORE=0.30
SMOKE_NO_SMOKE_VETO_SCORE=0.70
SMOKE_UNCERTAIN_SCORE=0.40

# Models
FIRE_CLASSIFIER_MODEL=EdBianchi/vit-fire-detection
CLIP_MODEL=openai/clip-vit-base-patch32
YOLO_MODEL_NAME=yolov8m.pt
YOLO_CONFIDENCE=0.25
USE_YOLO=true

# OCR
OCR_ENGINE=tesseract
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
